{
  "name": "startup-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "concurrently -k -n api,web -c cyan,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx apps/dashboard/server/server.ts",
    "dev:web": "vite --config apps/dashboard/vite.config.ts --host 0.0.0.0",
    "dev:worker": "tsx apps/worker/src/index.ts",
    "build": "npm run typecheck && vite build --config apps/dashboard/vite.config.ts",
    "typecheck": "tsc -p tsconfig.check.json --noEmit",
    "test": "tsx --test packages/shared/src/*.test.ts",
    "test:e2e": "playwright test -c playwright.config.cjs",
    "preview:dashboard": "npm run build && STARTUP_OS_SERVE_STATIC=true tsx apps/dashboard/server/server.ts"
  },
  "dependencies": {
    "@startup-os/shared": "file:packages/shared",
    "better-sqlite3": "9.6.0",
    "cors": "2.8.5",
    "express": "4.22.2",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1",
    "@types/better-sqlite3": "7.6.11",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "concurrently": "8.2.2",
    "tsx": "4.22.4",
    "typescript": "5.5.4",
    "vite": "6.4.2"
  },
  "overrides": {
    "esbuild": "0.28.0"
  }
}
